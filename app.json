{
  "expo": {
    "name": " ",
    "slug": "sfa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/space.png",
    "scheme": "sfa",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/space.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/space.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/space.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF"
        }
      ],
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
